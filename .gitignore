# Python / runtime caches
__pycache__/
*.py[cod]
.pytest_cache/

# Local environments and secrets
.env
.env.*
*.key
*.pem
secrets.*

# Editor and OS noise
.DS_Store
Thumbs.db
.vscode/
~$*

# Downloaded external repos or temporary raw mirrors
data/benchmarks/spider_raw/

# Large or local-only experiment scratch areas
tmp/
temp/

# Local paper copies and extracted figures.
# Keep bibliographic notes and README files in git; do not publish third-party PDFs/images.
docs/opening/papers/*.pdf
docs/opening/paper_figures/
